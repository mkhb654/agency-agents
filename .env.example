# ============================================================================
# Agency Hedge Fund - Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# Only the API key for your chosen LLM provider is required.
# ============================================================================

# ---------------------------------------------------------------------------
# LLM Configuration
# ---------------------------------------------------------------------------
# Supported providers: openai, anthropic, google, groq, deepseek, ollama
LLM_PROVIDER=openai

# Override the default model for the chosen provider.
# Defaults: openai=gpt-4.1, anthropic=claude-sonnet-4-20250514,
#           google=gemini-2.0-flash, groq=llama-3.3-70b-versatile,
#           deepseek=deepseek-chat, ollama=llama3.2
# LLM_MODEL=gpt-4.1

# Sampling temperature (0.0 = deterministic, higher = more creative)
# LLM_TEMPERATURE=0.0

# ---------------------------------------------------------------------------
# LLM Provider API Keys (set the one matching your LLM_PROVIDER)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=

# ---------------------------------------------------------------------------
# Financial Data
# ---------------------------------------------------------------------------
# API key for https://financialdatasets.ai
FINANCIAL_DATASETS_API_KEY=

# ---------------------------------------------------------------------------
# Portfolio Defaults
# ---------------------------------------------------------------------------
# Starting cash balance in USD
# INITIAL_CASH=100000

# Margin requirement as a decimal (0.50 = 50%)
# MARGIN_REQUIREMENT=0.50

# Maximum single-position size as a fraction of portfolio (0.25 = 25%)
# MAX_POSITION_SIZE_PCT=0.25

# Annualised risk-free rate for Sharpe ratio calculations
# RISK_FREE_RATE=0.045

# ---------------------------------------------------------------------------
# Cache
# ---------------------------------------------------------------------------
# TTL for in-memory cache entries in seconds (0 = no caching)
# CACHE_TTL_SECONDS=3600

# ---------------------------------------------------------------------------
# API Server
# ---------------------------------------------------------------------------
# API_HOST=0.0.0.0
# API_PORT=8000

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# SQLAlchemy connection string
# DATABASE_URL=sqlite+aiosqlite:///./hedge_fund.db
